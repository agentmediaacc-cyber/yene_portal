<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>YENE Portal | Create Account</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root{--yene:#4aa8ff;--bg:#0b1220;--card:#111b2e;--text:#eaf2ff;--muted:#a9b7d6;--line:rgba(255,255,255,.12);--danger:#ff5c5c;}
    *{box-sizing:border-box;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial}
    body{margin:0;min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);color:var(--text);padding:18px}
    .card{width:100%;max-width:520px;background:var(--card);border:1px solid var(--line);border-radius:18px;padding:18px}
    h1{margin:0 0 6px;font-size:20px}
    p{margin:0 0 14px;color:var(--muted);line-height:1.4}
    label{display:block;margin:10px 0 6px;color:var(--muted);font-size:12px;font-weight:800;letter-spacing:.4px;text-transform:uppercase}
    input{width:100%;padding:12px 12px;border-radius:12px;border:1px solid var(--line);background:#0b1427;color:var(--text);outline:none}
    input:focus{border-color:var(--yene)}
    .btn{width:100%;margin-top:14px;padding:12px;border-radius:12px;border:none;background:var(--yene);color:#041021;font-weight:1000;cursor:pointer}
    .btn:disabled{opacity:.6;cursor:not-allowed}
    .msg{margin-top:12px;padding:10px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.02);color:var(--muted);display:none}
    .msg.err{border-color:rgba(255,92,92,.5);background:rgba(255,92,92,.12);color:#ffd7d7}
    .top{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .logo{width:40px;height:40px;border-radius:14px;background:rgba(74,168,255,.18);display:flex;align-items:center;justify-content:center;color:var(--yene);font-size:18px;border:1px solid rgba(74,168,255,.28)}
    .small{font-size:12px;color:var(--muted);margin-top:8px}
    a{color:var(--yene);text-decoration:none}
  </style>
</head>
<body>

  <div class="card">
    <div class="top">
      <div class="logo"><i class="fa-solid fa-bolt"></i></div>
      <div>
        <h1>Create your YENE Agent Account</h1>
        <p>Enter your details to create the account. You will complete the full profile in the dashboard.</p>
      </div>
    </div>

    <label>Cellphone Number</label>
    <input id="phone" placeholder="+264..." autocomplete="tel" />

    <label>Email</label>
    <input id="email" type="email" placeholder="you@email.com" autocomplete="email" />

    <label>Password</label>
    <input id="password" type="password" placeholder="Minimum 6 characters" autocomplete="new-password" />

    <button class="btn" id="btn" onclick="createAccount()">
      <i class="fa-solid fa-user-plus"></i> Create Account
    </button>

    <div class="msg" id="msg"></div>
    <div class="small">Already have an account? <a href="/login">Login</a></div>
  </div>

  <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
  <script>
    const SUPABASE_URL = "https://kcxphxihykonzuagtgke.supabase.co";
    const SUPABASE_ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtjeHBoeGloeWtvbnp1YWd0Z2tlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE1ODQ3NTYsImV4cCI6MjA4NzE2MDc1Nn0.apk8My6XuGnv1374_q-r45QMYO2FYveWIlXuj12VCR0";

    const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON);

    function showMsg(text, isErr=false){
      const m = document.getElementById("msg");
      m.textContent = text;
      m.style.display = "block";
      m.className = "msg" + (isErr ? " err" : "");
    }

    async function createAccount(){
      const phone = document.getElementById("phone").value.trim();
      const email = document.getElementById("email").value.trim();
      const password = document.getElementById("password").value;

      if(!phone || phone.length < 7) return showMsg("Enter a valid phone number.", true);
      if(!email) return showMsg("Enter a valid email.", true);
      if(!password || password.length < 6) return showMsg("Password must be at least 6 characters.", true);

      const btn = document.getElementById("btn");
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating...';

      try{
        // 1) Create Auth account (email+password)
        const { data, error } = await sb.auth.signUp({ email, password });
        if(error) throw error;
        if(!data.user) throw new Error("Account not created.");

        const userId = data.user.id;

        // 2) Try to create minimal profile row (if RLS allows)
        // If insert fails due to RLS, we still redirect, and dashboard can create it later via server/admin.
        const { error: profileErr } = await sb.from("agent_profiles").insert([{
          id: userId,
          email: email,
          phone: phone,
          role: "AGENT",
          status: "PENDING"
        }]);

        if(profileErr){
          console.warn("Profile insert failed (likely RLS). Redirecting anyway:", profileErr.message);
        }

        showMsg("Account created. Redirecting to dashboard...");

        // 3) Redirect to dashboard where they complete full profile
        // Change this path to your real dashboard route if different:
        window.location.href = "/agent/dashboard";

      }catch(e){
        showMsg(e.message || "Failed. Try again.", true);
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-user-plus"></i> Create Account';
      }
    }
  </script>
</body>
</html>