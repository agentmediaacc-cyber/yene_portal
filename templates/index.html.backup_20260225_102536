{% extends 'base_public.html' %}
{% block title %}YENE Portal • Home{% endblock %}

{% block content %}

<div class="hero card">
  <div class="pill"><span class="dot ok"></span> Live Network • Namibia</div>
  <h1 style="margin-top:10px;">YENE Promoter & Agent Platform</h1>
  <p>
    A secure nationwide system to recruit drivers and clients, track verified trips, control commissions, prevent scammers,
    and scale YENE into every town across Namibia — with full admin oversight.
  </p>
  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px;">
    <a class="btn primary" href="/register"><i class="fa-solid fa-user-plus"></i> Apply / Register</a>
    <a class="btn" href="/login"><i class="fa-solid fa-right-to-bracket"></i> Login</a>
    <a class="btn" href="/admin"><i class="fa-solid fa-shield-halved"></i> Admin Command Center</a>
  </div>
  <div class="muted" style="margin-top:10px;">
    Admin controls: payments per town • commissions • approvals • broadcasts • security actions.
  </div>
</div>

<div class="kpis" style="margin-top:12px;">
  <div class="kpi">
    <div class="label">Agents / Promoters</div>
    <div class="value" id="kpiAgents">—</div>
    <div class="muted" id="kpiAgentsSub">Active / Pending / Blocked</div>
  </div>
  <div class="kpi">
    <div class="label">Drivers Registered</div>
    <div class="value" id="kpiDrivers">—</div>
    <div class="muted">Fleet monitoring</div>
  </div>
  <div class="kpi">
    <div class="label">Verified Trips</div>
    <div class="value" id="kpiTrips">—</div>
    <div class="muted">Admin verification</div>
  </div>
  <div class="kpi">
    <div class="label">Total Paid (NAD)</div>
    <div class="value" id="kpiPaid">—</div>
    <div class="muted">Commission + Bonus</div>
  </div>
</div>

<div class="grid" style="margin-top:12px;">
  <div class="card" id="features">
    <div class="section-title">
      <h2><i class="fa-solid fa-layer-group"></i> Platform Features (Admin + Agents)</h2>
      <span class="pill"><span class="dot warn"></span> Admin-controlled rules</span>
    </div>

    <ul class="muted" style="margin:0;line-height:1.7;">
      <li><b>Secure approvals</b>: Admin approves or blocks agents to stop scammers.</li>
      <li><b>National coverage</b>: Works in all 14 regions — add agents in every town.</li>
      <li><b>Driver & client onboarding</b>: agents register users; admin controls edits to prevent manipulation.</li>
      <li><b>Verified trip tracking</b>: admin verifies trips; dashboards update in real-time.</li>
      <li><b>Commission logic</b>: first-trip recruiter bonus, referral %, per-town commission rules.</li>
      <li><b>Finance ledger</b>: every payout logged (date, type, amount, agent).</li>
      <li><b>Broadcasts</b>: admin sends announcements to all agents.</li>
      <li><b>Fraud prevention</b>: duplicate detection on phone/ID (recommended via DB rules).</li>
      <li><b>Support security</b>: support role can reset passwords, block accounts, view audit logs.</li>
      <li><b>Invoices</b>: downloadable invoice statement for agents (generated by system).</li>
    </ul>
  </div>

  <div class="card">
    <div class="section-title">
      <h2><i class="fa-solid fa-bullhorn"></i> Admin Announcements</h2>
      <a class="btn" href="/admin"><i class="fa-solid fa-pen-to-square"></i> Manage</a>
    </div>
    <div class="muted">Latest broadcast messages controlled by admin:</div>

    <div id="broadcastList" style="margin-top:10px;display:flex;flex-direction:column;gap:10px;">
      <div class="muted">Loading announcements…</div>
    </div>
  </div>
</div>

<div class="card" id="payments" style="margin-top:12px;">
  <div class="section-title">
    <h2><i class="fa-solid fa-coins"></i> Payment Structure (Per Town / Region)</h2>
    <a class="btn" href="/admin"><i class="fa-solid fa-sliders"></i> Admin Control</a>
  </div>

  <div class="muted">
    These values are loaded from admin-controlled settings. Update once and it reflects on every device.
  </div>

  <div class="table-wrap" style="margin-top:10px;">
    <table>
      <thead>
        <tr>
          <th>Region</th>
          <th>Town</th>
          <th>Driver Registration (N$)</th>
          <th>Client Registration (N$)</th>
          <th>First Trip Bonus (N$)</th>
          <th>Referral %</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="paymentTable">
        <tr><td colspan="7" style="text-align:center;color:var(--muted);">Loading payment rules…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<div class="grid" style="margin-top:12px;" id="recruitment">
  <div class="card">
    <div class="section-title">
      <h2><i class="fa-solid fa-users"></i> We Need Agents In Every Town</h2>
      <a class="btn ok" href="/register"><i class="fa-solid fa-user-plus"></i> Apply Now</a>
    </div>
    <div class="muted" style="line-height:1.6;">
      Join as a verified YENE promoter. Admin approval is required. The system protects YENE and protects agents from fraud.
      You will receive official instructions, commission rules, and dashboard access.
    </div>

    <div class="muted" style="margin-top:10px;">
      Requirements (admin can change):
      <ul style="margin:6px 0 0;line-height:1.7;">
        <li>Valid national ID</li>
        <li>Phone number</li>
        <li>Town/region where you operate</li>
        <li>Profile photo</li>
      </ul>
    </div>
  </div>

  <div class="card">
    <div class="section-title">
      <h2><i class="fa-solid fa-shield"></i> Safety & Anti-Scam Rules</h2>
      <span class="pill"><span class="dot ok"></span> Trusted onboarding</span>
    </div>
    <div class="muted" style="line-height:1.7;">
      <ul style="margin:0;line-height:1.7;">
        <li>Only approved agents can work and earn.</li>
        <li>Admin controls edits to driver/client details.</li>
        <li>Duplicate checks on phone/ID to stop fake registrations.</li>
        <li>Online/offline tracking for monitoring activity.</li>
        <li>All payments logged in the finance ledger.</li>
      </ul>
    </div>
  </div>
</div>

<script src="https://unpkg.com/@supabase/supabase-js@2"></script>
<script>
  // Supabase public keys (Safe to be public as long as Row Level Security (RLS) is enabled in Supabase)
  const SUPABASE_URL = "https://kcxphxihykonzuagtgke.supabase.co";
  const SUPABASE_ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtjeHBoeGloeWtvbnp1YWd0Z2tlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE1ODQ3NTYsImV4cCI6MjA4NzE2MDc1Nn0.apk8My6XuGnv1374_q-r45QMYO2FYveWIlXuj12VCR0";

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON);

  function esc(s){
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  async function loadIndexData(){
    // KPI: agents
    const a = await sb.from("agents").select("id,status");
    const agents = a.data || [];
    const active = agents.filter(x=>x.status==="ACTIVE").length;
    const pending = agents.filter(x=>x.status==="PENDING").length;
    const blocked = agents.filter(x=>x.status==="BLOCKED").length;
    document.getElementById("kpiAgents").textContent = agents.length.toString();
    document.getElementById("kpiAgentsSub").textContent = `Active ${active} • Pending ${pending} • Blocked ${blocked}`;

    // KPI: drivers + trips
    const d = await sb.from("drivers").select("id,verified_trips");
    const drivers = d.data || [];
    document.getElementById("kpiDrivers").textContent = drivers.length.toString();
    const trips = drivers.reduce((s,x)=>s + Number(x.verified_trips||0), 0);
    document.getElementById("kpiTrips").textContent = trips.toString();

    // KPI: total paid
    const f = await sb.from("finance_ledger").select("amount");
    const fin = f.data || [];
    const paid = fin.reduce((s,x)=>s + Number(x.amount||0), 0);
    document.getElementById("kpiPaid").textContent = "N$ " + paid.toLocaleString();

    // Broadcasts
    const b = await sb.from("broadcasts").select("message,created_at").order("created_at",{ascending:false}).limit(6);
    const broadcasts = b.data || [];
    const holder = document.getElementById("broadcastList");
    holder.innerHTML = broadcasts.length ? broadcasts.map(x => `
      <div class="card" style="background:rgba(255,255,255,.02);border-radius:16px;">
        <div style="font-weight:900;">${esc(x.message)}</div>
        <div class="muted" style="margin-top:6px;font-size:12px;">${new Date(x.created_at).toLocaleDateString()}</div>
      </div>
    `).join("") : `<div class="muted">No announcements yet.</div>`;

    // Payment rules per town
    const p = await sb.from("payment_rules").select("*").order("region",{ascending:true}).order("town",{ascending:true}).limit(300);
    const rules = p.data || [];
    const tb = document.getElementById("paymentTable");
    tb.innerHTML = rules.length ? rules.map(r => `
      <tr>
        <td>${esc(r.region)}</td>
        <td><b>${esc(r.town)}</b></td>
        <td>${esc(r.driver_reg || 0)}</td>
        <td>${esc(r.client_reg || 0)}</td>
        <td>${esc(r.first_trip_bonus || 0)}</td>
        <td>${esc(r.referral_pct || 0)}%</td>
        <td>${r.is_active ? "Active" : "Inactive"}</td>
      </tr>
    `).join("") : `<tr><td colspan="7" style="text-align:center;color:var(--muted);">No payment rules found. Create rows in payment_rules.</td></tr>`;
  }

  loadIndexData().catch(err=>{
    console.error("Supabase Error:", err);
    const tb = document.getElementById("paymentTable");
    tb.innerHTML = `<tr><td colspan="7" style="text-align:center;color:var(--muted);">Error loading data. Check Supabase tables/policies.</td></tr>`;
    document.getElementById("broadcastList").innerHTML = `<div class="muted">Error loading announcements.</div>`;
  });
</script>

{% endblock %}