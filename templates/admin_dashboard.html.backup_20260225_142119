    function applyFilters() {
        const region = document.getElementById('region-filter').value;
        const q = document.getElementById('masterSearch').value.toLowerCase().trim();
        let filtered = allUsers;
        if(region !== "ALL") filtered = filtered.filter(u => u.region === region);
        if(q !== "") {
            filtered = filtered.filter(u => 
                (u.full_name||"").toLowerCase().includes(q) || 
                (u.id_number||"").includes(q) || 
                (u.phone||"").includes(q)
            );
            document.getElementById('search-count').innerText = `${filtered.length} found`;
        } else {
            document.getElementById('search-count').innerText = "";
        }
        
        document.getElementById('s-total').innerText = filtered.length;
        document.getElementById('s-pending').innerText = filtered.filter(u => u.status === 'pending_approval').length;
        document.getElementById('s-active').innerText = filtered.filter(u => u.status === 'active').length;
        renderTable(filtered);
    }

    function renderTable(data) {
        document.getElementById('agent-table-body').innerHTML = data.map(u => `
            <tr>
                <td><span class="clickable-name" onclick="openProfile('${u.id}')">${u.full_name || 'No Name'}</span></td>
                <td>${u.region}</td>
                <td style="color:${u.status === 'active' ? 'var(--ok)' : 'var(--warn)'}">${u.status}</td>
                <td>${new Date(u.created_at).toLocaleDateString()}</td>
            </tr>
        `).join('');
    }

    function openProfile(id) {
