@app.route("/api/admin/create_user_v2", methods=["POST"])
@require_login("ADMIN")
def admin_create_user_final():
    try:
        data = request.json or {}

        email = (data.get("email") or "").strip().lower()
        password = data.get("password") or ""
        full_name = (data.get("full_name") or "").strip()
        username = (data.get("username") or "").strip().lower()
        phone = (data.get("phone") or "").strip()
        role = (data.get("role") or "AGENT").strip().upper()

        if not email or len(password) < 6:
            return jsonify({"success": False, "error": "Email required and password must be at least 6 characters."}), 400
        if not username:
            return jsonify({"success": False, "error": "Username is required."}), 400

        # 1) Create Supabase Auth user (service role)
        res = sb_admin.auth.admin.create_user({
            "email": email,
            "password": password,
            "email_confirm": True,
            "user_metadata": {"full_name": full_name}
        })

        user_id = res.user.id

        # 2) Insert profile row (agent_profiles)
        # NOTE: Your table earlier did NOT have auth_id, so we store the auth user id in "id".
        sb_admin.table("agent_profiles").insert({
            "id": user_id,
            "username": username,
            "full_name": full_name,
            "email": email,
            "phone": phone,
            "role": role,
            "status": "pending_approval"
        }).execute()

        log_system_event("USER_CREATION", f"Admin created agent: {email}", user_id=user_id)
        return jsonify({"success": True, "message": "Account Created (Pending Approval)!"})

    except Exception as e:
        msg = str(e)
        low = msg.lower()
        if "already registered" in low or "user already exists" in low:
            msg = "This email is already registered."
        return jsonify({"success": False, "error": msg}), 400


