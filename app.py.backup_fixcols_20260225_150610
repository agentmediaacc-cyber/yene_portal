        "auth_id": auth_id,
        "full_name": full_name,
        "email": email,
        "username": username,
        "phone": phone,
        "role": role,
        "status": "PENDING" if role == "AGENT" else "ACTIVE"
    }).execute()

    try:
        sb_admin.table("system_logs").insert({
            "event_type": "USER_CREATE",
            "description": f"Admin created {role}: {email}",
            "user_id": session.get("user_id"),
            "ip_address": request.remote_addr
        }).execute()
    except Exception:
        pass

    return jsonify({"success": True})

@app.route("/api/admin/export/<kind>")
def api_admin_export(kind):
    if not _require_admin():
        return "Not authorized", 401

    if kind == "agents":
        rows = sb_admin.table("agents").select("*").order("created_at", desc=True).limit(10000).execute().data or []
    elif kind == "drivers":
        rows = sb_admin.table("drivers").select("*").order("created_at", desc=True).limit(20000).execute().data or []
    elif kind == "clients":
        rows = sb_admin.table("clients").select("*").order("created_at", desc=True).limit(20000).execute().data or []
    elif kind == "finance":
        rows = sb_admin.table("finance_ledger").select("*").order("created_at", desc=True).limit(50000).execute().data or []
    else:
        return "Bad export type", 400

    # Build CSV
    import csv, io
    out = io.StringIO()
    if not rows:
        out.write("")
    else:
        fieldnames = sorted({k for r in rows for k in r.keys()})
        w = csv.DictWriter(out, fieldnames=fieldnames)
        w.writeheader()
        for r in rows:
            w.writerow({k: r.get(k, "") for k in fieldnames})

    resp = Response(out.getvalue(), mimetype="text/csv; charset=utf-8")
    resp.headers["Content-Disposition"] = f'attachment; filename="{kind}.csv"'
    return resp

