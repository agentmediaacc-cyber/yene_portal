@app.route("/api/admin/overview")
def api_admin_overview():
    if not _require_admin():
        return jsonify({"success": False, "error": "Not authorized"}), 401

    # Agents
    agents = sb_admin.table("agents").select("id,status").execute().data or []
    active = len([a for a in agents if (a.get("status") or "").upper() == "ACTIVE"])
    pending = len([a for a in agents if (a.get("status") or "").upper() == "PENDING"])
    blocked = len([a for a in agents if (a.get("status") or "").upper() == "BLOCKED"])

    # Drivers + clients
    drivers = sb_admin.table("drivers").select("id,created_at,full_name,phone,town,recruiter_name,recruiter_agent_id").order("created_at", desc=True).limit(15).execute().data or []
    clients = sb_admin.table("clients").select("id,created_at,full_name,phone,recruiter_name,recruiter_agent_id").order("created_at", desc=True).limit(15).execute().data or []

    # Finance totals
    ledger = sb_admin.table("finance_ledger").select("amount").execute().data or []
    total_paid = sum(float(x.get("amount") or 0) for x in ledger)

    recent = []
    for d in drivers:
        recent.append({
            "created_at": d.get("created_at"),
            "type": "DRIVER",
            "name": d.get("full_name"),
            "phone": d.get("phone"),
            "town": d.get("town"),
            "recruiter_name": d.get("recruiter_name"),
            "recruiter_id": d.get("recruiter_agent_id"),
        })
    for c in clients:
        recent.append({
            "created_at": c.get("created_at"),
            "type": "CLIENT",
            "name": c.get("full_name"),
            "phone": c.get("phone"),
            "town": "",
            "recruiter_name": c.get("recruiter_name"),
            "recruiter_id": c.get("recruiter_agent_id"),
        })
    recent = sorted(recent, key=lambda x: x.get("created_at") or "", reverse=True)[:25]

    return jsonify({"success": True, "data": {
        "agents_total": len(agents),
        "agents_active": active,
        "agents_pending": pending,
        "agents_blocked": blocked,
        "drivers_total": sb_admin.table("drivers").select("id").execute().data and len(sb_admin.table("drivers").select("id").execute().data) or 0,
        "clients_total": sb_admin.table("clients").select("id").execute().data and len(sb_admin.table("clients").select("id").execute().data) or 0,
        "total_paid": total_paid,
        "recent_activity": recent
    }})


@app.route("/api/admin/agents_auth_stats")
def api_admin_agents_auth_stats():
    if not _require_admin():
        return jsonify({"success": False, "error": "Not authorized"}), 401

    # 1) Count users in Supabase Auth (real authentication users)
    # Uses Auth Admin REST endpoint with SERVICE ROLE key
    auth_count = 0
    try:
        url = URL.rstrip("/") + "/auth/v1/admin/users"
        headers = {
            "Authorization": f"Bearer {SERVICE_KEY}",
            "apikey": SERVICE_KEY
        }
        page = 1
        per_page = 200

        while True:
            r = requests.get(url, headers=headers, params={"page": page, "per_page": per_page}, timeout=20)
            r.raise_for_status()
            users = r.json() or []
            auth_count += len(users)
            if len(users) < per_page:
                break
            page += 1
    except Exception as e:
        # If auth listing fails, keep auth_count=0 but still return DB counts
        print("Auth list_users error:", e)

    # 2) Count agents in DB table (profiles)
    agents = sb_admin.table("agents").select("id,status").execute().data or []
    total_agents_db = len(agents)
    pending_db = len([a for a in agents if (a.get("status") or "").upper() == "PENDING"])
    active_db = len([a for a in agents if (a.get("status") or "").upper() == "ACTIVE"])
    blocked_db = len([a for a in agents if (a.get("status") or "").upper() == "BLOCKED"])

    return jsonify({
        "success": True,
        "data": {
            "auth_users_total": auth_count,
            "agents_db_total": total_agents_db,
            "agents_db_pending": pending_db,
            "agents_db_active": active_db,
            "agents_db_blocked": blocked_db
        }
    })


@app.route("/api/admin/agents")
def api_admin_agents():
    if not _require_admin():
        return jsonify({"success": False, "error": "Not authorized"}), 401

    agents = sb_admin.table("agents").select("*").order("created_at", desc=True).limit(2000).execute().data or []

    # counts per agent for drivers/clients
    drivers = sb_admin.table("drivers").select("recruiter_agent_id").execute().data or []
    clients = sb_admin.table("clients").select("recruiter_agent_id").execute().data or []

    counts = {}
    for d in drivers:
        aid = d.get("recruiter_agent_id")
        if not aid: continue
        counts.setdefault(aid, {"drivers":0, "clients":0})
        counts[aid]["drivers"] += 1
    for c in clients:
        aid = c.get("recruiter_agent_id")
        if not aid: continue
        counts.setdefault(aid, {"drivers":0, "clients":0})
        counts[aid]["clients"] += 1

    return jsonify({"success": True, "data": {"agents": agents, "counts": counts}})

