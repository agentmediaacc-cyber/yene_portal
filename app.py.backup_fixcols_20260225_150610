@app.route("/api/admin/approve_agent", methods=["POST"])
@require_login("ADMIN")
def approve_agent():
    """
    Approve / block / suspend an agent profile.
    Expects JSON:
      { "agent_id": "<uuid>", "status": "ACTIVE" | "PENDING" | "BLOCKED" | "SUSPENDED" }
    """
    try:
        data = request.json or {}
        agent_id = (data.get("agent_id") or "").strip()
        status = (data.get("status") or "ACTIVE").strip().upper()

        if not agent_id:
            return jsonify({"success": False, "error": "agent_id is required"}), 400

        allowed = {"ACTIVE", "PENDING", "BLOCKED", "SUSPENDED"}
        if status not in allowed:
            return jsonify({"success": False, "error": f"Invalid status. Use: {', '.join(sorted(allowed))}"}), 400

        sb_admin.table("agent_profiles").update({"status": status}).eq("id", agent_id).execute()

        log_system_event("AGENT_STATUS", f"Admin set agent {agent_id} status -> {status}", user_id=agent_id)
        return jsonify({"success": True, "message": f"Agent status updated to {status}"}), 200

    except Exception as e:
        return jsonify({"success": False, "error": str(e)}), 400


