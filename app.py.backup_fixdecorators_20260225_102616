@app.route("/login", methods=["GET", "POST"])
def login():
    if request.method == "POST":
        username = (request.form.get("username") or "").strip().lower()
        password = request.form.get("password") or ""

        if not username or not password:
            flash("Enter username and password.")
            return redirect(url_for("login"))

        try:
            # ---- Check Agents ----
            agent_check = supabase.table("agent_profiles") \
                .select("id, email, status, username, full_name, role") \
                .eq("username", username) \
                .limit(1).execute()

            if agent_check.data:
                agent = agent_check.data[0]
                status = (agent.get("status") or "").lower()

                if status in ["pending_approval", "pending"]:
                    flash("Your account is still pending admin approval.")
                    return redirect(url_for("login"))

                if status in ["blocked", "suspended"]:
                    flash("Your account is blocked. Contact admin.")
                    return redirect(url_for("login"))

                # Verify password via Supabase Auth
                supabase.auth.sign_in_with_password({"email": agent["email"], "password": password})

                # Create session
                session["role"] = "AGENT"
                session["user_id"] = agent["id"]
                session["username"] = agent.get("username")
                session["full_name"] = agent.get("full_name")
                session["email"] = agent.get("email")

                log_system_event("LOGIN", f"Agent login: {agent.get('email')}", user_id=agent["id"])
                return redirect(url_for("agent_dashboard"))

            # ---- Check Admins ----
            admin_check = supabase.table("admin_profiles") \
                .select("id, email, username, full_name") \
                .eq("username", username) \
                .limit(1).execute()

            if admin_check.data:
                admin = admin_check.data[0]

                supabase.auth.sign_in_with_password({"email": admin["email"], "password": password})

                session["role"] = "ADMIN"
                session["user_id"] = admin["id"]
                session["username"] = admin.get("username")
                session["full_name"] = admin.get("full_name")
                session["email"] = admin.get("email")

                log_system_event("LOGIN", f"Admin login: {admin.get('email')}", user_id=admin["id"])
                return redirect(url_for("admin_dashboard"))

            flash("Username not found.")
            return redirect(url_for("login"))

        except Exception as e:
            flash(f"Login error: {str(e)}")
            return redirect(url_for("login"))

    return render_template("login.html")

