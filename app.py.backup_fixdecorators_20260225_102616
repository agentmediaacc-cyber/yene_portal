@app.route("/api/admin/create_user_v2", methods=["POST"])
@require_login("ADMIN")
def admin_create_user_final():
    try:
        data = request.json or {}

        email = (data.get("email") or "").strip().lower()
        password = data.get("password") or ""
        full_name = (data.get("full_name") or "").strip()
        username = (data.get("username") or "").strip().lower()
        phone = (data.get("phone") or "").strip()
        role = (data.get("role") or "AGENT").strip().upper()

        if not email or len(password) < 6:
            return jsonify({"success": False, "error": "Email required and password must be at least 6 characters."}), 400
        if not username:
            return jsonify({"success": False, "error": "Username is required."}), 400

        # Create Supabase Auth user
        res = sb_admin.auth.admin.create_user({
            "email": email,
            "password": password,
            "email_confirm": True,
            "user_metadata": {"full_name": full_name}
        })

        user_id = res.user.id

        # Create agent profile in DB
        sb_admin.table("agent_profiles").insert({
            "id": user_id,                  # best practice: keep same id as auth user
            "auth_id": user_id,
            "full_name": full_name,
            "username": username,
            "email": email,
            "phone": phone,
            "role": role,
            "status": "pending_approval",
            "created_at": datetime.utcnow().isoformat()
        }).execute()

        log_system_event("USER_CREATION", f"Admin created user: {email}", user_id=user_id)

        return jsonify({"success": True, "message": "Account Created! Pending approval.", "user_id": user_id})

    except Exception as e:
        err_msg = str(e)
        if "already registered" in err_msg.lower():
            err_msg = "This email is already registered."
        if "duplicate key" in err_msg.lower() or "unique constraint" in err_msg.lower():
            err_msg = "Username/email/phone already exists."
        return jsonify({"success": False, "error": err_msg}), 400

